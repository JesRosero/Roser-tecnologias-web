RewriteEngine On

# Redirect /productos/ to /Marketplace/productos/
RewriteRule ^productos/(.*)$ Marketplace/productos/$1 [R=301,L]

# Redirect /impresion-3d.html to /Servicios/impresiones-3d.html
RewriteRule ^impresion-3d\.html$ Servicios/impresiones-3d.html [R=301,L]

# Handle missing files - redirect to index if file doesn't exist
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.html [L]